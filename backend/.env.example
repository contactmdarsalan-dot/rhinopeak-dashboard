# RhinoPeak Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets to version control.

# ── Security ───────────────────────────────────────────────────────────────
# REQUIRED in production. Must be ≥32 random characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RHINOPEAK_SECRET_KEY=

# Set to "0" in production to enforce all safety checks
RHINOPEAK_DEBUG=0

# Comma-separated list of allowed hostnames (no wildcards).
# Example: api.rhinopeak.com,your-domain.com
RHINOPEAK_ALLOWED_HOSTS=

# ── Database ──────────────────────────────────────────────────────────────
RHINOPEAK_MONGO_URI=mongodb://localhost:27017
RHINOPEAK_MONGO_DB_NAME=rhinopeak_dashboard
RHINOPEAK_MONGO_TIMEOUT_MS=3000

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests.
# Do NOT use "*" in production.
RHINOPEAK_CORS_ORIGINS=https://your-frontend.com,https://app.your-domain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────
# Optional: use Redis for distributed rate limiting.
# Leave blank to use in-memory store (single-instance dev only).
RHINOPEAK_REDIS_URL=redis://localhost:6379/0

# ── Frontend / Backend URLs ───────────────────────────────────────────────
# Used for building redirect URLs in payment callbacks and email links.
RHINOPEAK_FRONTEND_URL=https://your-frontend.com
RHINOPEAK_BACKEND_URL=https://api.your-domain.com

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-api-key
BREVO_SMTP_PASS=
RHINOPEAK_FROM_EMAIL=noreply@your-domain.com
RHINOPEAK_FROM_NAME=RhinoPeak Business

# ── eSewa Payment Gateway (sandbox) ──────────────────────────────────────
# Get test credentials from: https://developer.esewa.com.np/
# Use EPAYTEST as merchant code for sandbox testing.
# The secret key "8gBm/:&EnhH.1/q" is eSewa's official sandbox secret.
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_BASE_URL=https://rc-epay.esewa.com.np  # sandbox endpoint

# ── Khalti Payment Gateway (sandbox) ────────────────────────────────────
# Get test credentials from: https://dashboard.khalti.com/merchant/
# Use test_public_key / test_secret_key for sandbox testing.
KHALTI_PUBLIC_KEY=test_public_key
KHALTI_SECRET_KEY=test_secret_key
KHALTI_BASE_URL=https://a.khalti.com  # sandbox endpoint

# ── Sessions ─────────────────────────────────────────────────────────────
RHINOPEAK_SESSION_TTL_MINUTES=60
RHINOPEAK_REFRESH_TTL_DAYS=30
RHINOPEAK_PASSWORD_RESET_TTL_MINUTES=15

# Set to "0" in production to hide reset tokens from URL
RHINOPEAK_EXPOSE_RESET_TOKEN=0

# ── Platform Setup ───────────────────────────────────────────────────────
# Secret token for initial platform owner bootstrap (rotate after use)
RHINOPEAK_PLATFORM_SETUP_TOKEN=